# Nervefeyn 的可选运行时默认值。
# 提供商凭据由 pi-coding-agent 按常规方式读取。

FEYNMAN_MODEL=
FEYNMAN_THINKING=medium
# PostHog 遥测默认指向为本仓库创建的 Nervefeyn 项目。
# 设置 FEYNMAN_TELEMETRY=off 可禁用,或覆盖这些值以指向另一个 PostHog 项目。
FEYNMAN_TELEMETRY=1
FEYNMAN_POSTHOG_HOST=https://us.i.posthog.com
FEYNMAN_POSTHOG_PROJECT_ID=479027
FEYNMAN_POSTHOG_KEY=
# Nervefeyn 内置的 pi-otel 扩展把 gen_ai.* Pi/插件 span 发送到 PostHog AI Observability,
# 不含提示或工具 payload 内容。CLI span/日志使用 PostHog 分布式追踪/日志。
PI_OTEL_CAPTURE_CONTENT=metadata_only

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ZAI_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
CEREBRAS_API_KEY=
HF_TOKEN=
OPENCODE_API_KEY=
AI_GATEWAY_API_KEY=
AZURE_OPENAI_API_KEY=

RUNPOD_API_KEY=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
