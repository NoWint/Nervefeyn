---
import Layout from "@/layouts/main.astro"
import { Button } from "@/components/ui/button"
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "@/components/ui/card"

const workflows = [
  { command: "/deepresearch", description: "跨论文、网页与代码的多代理调查" },
  { command: "rank", description: "PaperRank 评分,决定先读什么,附带图谱与方法学证据" },
  { command: "/lit", description: "基于一手文献的文献综述,带共识映射" },
  { command: "/review", description: "内部研究评审,带严重度评分与修订计划" },
  { command: "/audit", description: "针对可复现性声明的论文与代码差异审计" },
  { command: "/replicate", description: "在执行前先选择环境的复现计划" },
  { command: "/recipe", description: "基于论文、数据集、文档与代码的排序 ML 训练配方" },
  { command: "/compare", description: "并排来源对比,带一致与冲突矩阵" },
  { command: "/draft", description: "带行内引用的论文风格初稿,源自研究发现" },
  { command: "/autoresearch", description: "有界循环:假设、实验、度量、重复" },
  { command: "/watch", description: "研究监视基线,可选定时后续检查" },
]

const agents = [
  { name: "Researcher", description: "跨论文、网页、仓库与文档搜集证据" },
  { name: "Reviewer", description: "按严重度给声明打分,标记缺口并建议修订" },
  { name: "Writer", description: "将笔记组织为简报、初稿与论文风格输出" },
  { name: "Verifier", description: "检查引用、验证 URL、移除死链" },
]

const sources = [
  { name: "Nervefeyn Bio Tools", description: "面向开放科学的连接器,覆盖文献、PubMed 元数据、ID 转换、相关文章、引用匹配、版权检查、PMC 全文路由、bioRxiv/medRxiv 预印本窗口、DOI 查询、已发表链接、资助方/ROR 查询、预印本统计、Europe PMC 开放获取全文段落、引用图谱、作者、期刊、OA 状态、ClinicalTrials.gov 试验详情、赞助方、入选标准、研究者、终点、Grants.gov 机会、FDA 标签、不良事件、召回、Drugs@FDA 申请、申请计数、药理分类、仿药等同物、ChEMBL 化合物、药物适应症、ADMET 属性、生物活性、机制、靶点、基因、BioMart、CellGuide、PanglaoDB 标记基因与基因到细胞类型查询、Antibody Registry RRID 与目录查询、试剂、细胞类型、代谢组学、基因组轨迹、精确的 ENCODE/JASPAR/UniBind 调控工作流、UniBind TF-DNA 结合、精确的 gnomAD/CADD/ClinVar/dbSNP 变异工作流、GTEx 表达与 eQTL 工作流、KEGG 交叉链接与 ID 转换、InterPro/Pfam 蛋白结构域、Rfam RNA 家族模型与序列搜索、ArrayExpress/GEO/MetaboLights/MGnify/PRIDE 存档项目/样本/文件/分析/蛋白证据工作流、Human Protein Atlas 记录、STRING 网络与同源、可购买的 ZINC 化合物、GWAS、eQTL、蛋白、预测结构、EM 图谱、复合物、相互作用、组学、化学、通路与肿瘤组学" },
  { name: "AlphaXiv", description: "通过 alpha CLI 进行论文搜索、问答、代码阅读与标注", href: "https://alphaxiv.org" },
  { name: "Hugging Face Hub", description: "数据集 schema、仓库文件与小文本文件检查" },
  { name: "Web search", description: "通过 Exa、Perplexity 或 Gemini API 进行搜索" },
  { name: "Session search", description: "跨历史研究会话的索引召回" },
  { name: "Preview", description: "本地查看器,支持报告、PDF、媒体、电子表格、笔记本、LaTeX、KET/RXN/CDXML/CXSMILES 化学、结构、基因组、比对、树与张量" },
]

const workbenchFeatures = [
  { name: "项目控制平面", description: "项目、会话、frame 记录、上传-frame 链接、frame 健康记录、上手上下文与专家选择都保存在 Nervefeyn 的工作区状态中" },
  { name: "Pi 聊天与工具", description: "聊天通过本地 Pi 会话运行,带 frame 行、frame 消息行、转录、工具活动、附件与命令插入" },
  { name: "科研产物", description: "报告、数据文件、媒体、电子表格、笔记本、LaTeX、化学草图、结构、基因组、预览、版本、血缘、执行日志与验证检查可一起浏览" },
  { name: "Nervefeyn 自有设置", description: "Bio 连接器、frame 记录、frame 消息记录、frame 健康记录、监视例程记录、技能来源/许可证记录、设置决策记录、评审反馈记录、计算轮询租约、记忆分类、权限、计算提供方与脱敏凭据可用性不依赖其他本地应用" },
]

const compute = [
  { name: "Docker", description: "为显式选择的复现与基准运行提供隔离容器", href: "https://www.docker.com/" },
  { name: "Modal", description: "为有界研究基准任务提供突发 GPU 执行", href: "https://modal.com/" },
  { name: "RunPod", description: "为长时间运行的研究实验提供带 SSH 的持久 GPU pod", href: "https://www.runpod.io/" },
]

const terminalCommands = [
  { command: 'nervefeyn "scaling laws 我们知道些什么"', description: "来自论文与网页的带引用研究简报" },
  { command: 'nervefeyn rank "sparse autoencoders"', description: "PaperRank 表,带引用、图谱、方法学与可复现性评分" },
  { command: "nervefeyn serve", description: "本地科研工作台,带 Pi 聊天、Bio Tools、笔记本、计算、产物、溯源、技能与设置" },
  { command: 'nervefeyn deepresearch "mechanistic interpretability"', description: "带综合与验证的多代理深度调查" },
  { command: 'nervefeyn lit "RLHF alternatives"', description: "带共识与开放问题的文献综述" },
  { command: "nervefeyn audit 2401.12345", description: "论文声明 vs. 代码实际行为" },
  { command: 'nervefeyn replicate "chain-of-thought improves math"', description: "复现计划、计算目标、受控实验步骤" },
  { command: 'nervefeyn recipe "fine-tune a small model for math reasoning"', description: "排序的、可实现的 ML 训练配方" },
]

const installCommands = [
  { label: "curl", command: "curl -fsSL https://nervefeyn.dev/install | bash" },
  { label: "npm", command: "npm install -g @nowint/nervefeyn" },
]
---

<Layout title="Nervefeyn — 开源 AI 研究助手" active="home">
  <div class="mx-auto max-w-5xl px-6">

    <section class="flex flex-col items-center gap-8 pb-16 pt-20 text-center">
      <div class="flex max-w-3xl flex-col gap-4">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
          开源 AI<br />研究助手
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-muted-foreground">
          阅读论文、搜索网页、撰写研究初稿、规划实验,并为研究声明附上引用。从终端使用,或打开本地科研工作台进行聊天、产物、笔记本、计算与溯源。
        </p>
        <p class="text-sm text-muted-foreground">
          由{" "}
          <a href="https://github.com/NoWint" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">
            NoWint
          </a>
          {" "}制作
        </p>
      </div>

      <div class="flex w-full max-w-3xl flex-col items-center gap-4">
        <div class="flex w-full max-w-full flex-col">
          <div class="flex max-w-full self-start overflow-x-auto">
            {installCommands.map((entry, i) => (
              <button
                class:list={[
                  "install-toggle shrink-0 px-4 py-2 text-sm font-medium transition-colors cursor-pointer",
                  i === 0 ? "rounded-tl-lg" : "",
                  i === installCommands.length - 1 ? "rounded-tr-lg" : "",
                  entry.label === installCommands[0].label
                    ? "bg-muted text-foreground"
                    : "bg-muted/30 text-muted-foreground hover:text-foreground hover:bg-muted/50",
                ]}
                data-command={entry.command}
                aria-label={`显示 ${entry.label} 安装命令`}
              >
                {entry.label}
              </button>
            ))}
          </div>
          <button
            id="install-cmd"
            class="group flex w-full min-w-0 max-w-full items-start justify-between gap-3 rounded-b-lg rounded-tr-lg bg-muted px-4 py-3 text-left font-mono text-xs transition-colors hover:bg-muted/80 cursor-pointer sm:items-center sm:text-sm"
            data-command={installCommands[0].command}
            aria-label="复制安装命令"
          >
            <span id="install-command" class="flex-1 min-w-0 break-all whitespace-normal leading-relaxed sm:overflow-hidden sm:text-ellipsis sm:whitespace-nowrap">{installCommands[0].command}</span>
            <svg id="install-copy" class="mt-0.5 size-4 shrink-0 text-muted-foreground transition-colors group-hover:text-foreground sm:mt-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <svg id="install-check" class="mt-0.5 hidden size-4 shrink-0 text-primary sm:mt-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
          </button>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="/docs/getting-started/installation">
            <Button client:load size="lg">开始使用</Button>
          </a>
          <a href="https://github.com/NoWint/Nervefeyn" target="_blank" rel="noopener noreferrer" class="inline-flex h-10 items-center justify-center gap-2 rounded-md border border-input bg-background px-4 text-sm font-medium text-foreground transition-colors hover:bg-accent hover:text-accent-foreground">
            GitHub
          </a>
        </div>

        <p class="text-sm text-muted-foreground">
          使用 curl 获取打包运行时,或在你已本地管理 Node 时使用 npm。
        </p>

        <p class="text-sm text-muted-foreground">
          只需要技能? <a href="/docs/getting-started/installation" class="text-primary hover:underline">安装仅技能包</a>。
        </p>
      </div>

      <img src="/hero.png" class="w-full" alt="Nervefeyn CLI" />
    </section>

    <section class="py-16">
      <div class="flex flex-col items-center gap-8 text-center">
        <div class="flex flex-col gap-2">
          <h2 class="text-2xl font-bold sm:text-3xl">本地科研工作台</h2>
          <p class="max-w-2xl text-muted-foreground">
            `nervefeyn serve` 打开一个独立的 Nervefeyn 应用,适用于需要聊天、文件、工具、笔记本与审计轨迹的研究运行。
          </p>
        </div>
        <div class="grid w-full gap-4 sm:grid-cols-2">
          {workbenchFeatures.map((feature) => (
            <Card client:load size="sm" className="text-left">
              <CardHeader client:load>
                <CardTitle client:load>{feature.name}</CardTitle>
                <CardDescription client:load>{feature.description}</CardDescription>
              </CardHeader>
            </Card>
          ))}
        </div>
        <a href="/docs/getting-started/workbench">
          <Button client:load variant="outline">打开工作台文档</Button>
        </a>
      </div>
    </section>

    <section class="py-16">
      <div class="flex flex-col items-center gap-8 text-center">
        <div class="flex flex-col gap-2">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">你输入什么 &rarr; 发生什么</h2>
          <p class="text-muted-foreground">提出研究问题或运行工作流。研究声明都附带引用。</p>
        </div>
        <Card client:load className="w-full text-left">
          <CardContent client:load>
            <div class="flex flex-col gap-3 font-mono text-sm">
              {terminalCommands.map((cmd) => (
                <div class="flex flex-col gap-0.5">
                  <span class="text-primary">{cmd.command}</span>
                  <span class="text-xs text-muted-foreground">{cmd.description}</span>
                </div>
              ))}
            </div>
          </CardContent>
        </Card>
      </div>
    </section>

    <section class="py-16">
      <div class="flex flex-col items-center gap-8 text-center">
        <div class="flex flex-col gap-2">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">工作流</h2>
          <p class="text-muted-foreground">斜杠命令或自然语言,由你选择。</p>
        </div>
        <div class="grid w-full gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {workflows.map((wf) => (
            <Card client:load size="sm">
              <CardHeader client:load>
                <CardTitle client:load className="font-mono text-sm text-primary">{wf.command}</CardTitle>
                <CardDescription client:load>{wf.description}</CardDescription>
              </CardHeader>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="flex flex-col items-center gap-8 text-center">
        <div class="flex flex-col gap-2">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">代理</h2>
          <p class="text-muted-foreground">当研究任务需要时,专家代理会加入。</p>
        </div>
        <div class="grid w-full gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {agents.map((agent) => (
            <Card client:load size="sm" className="text-center">
              <CardHeader client:load className="items-center">
                <CardTitle client:load>{agent.name}</CardTitle>
                <CardDescription client:load>{agent.description}</CardDescription>
              </CardHeader>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="flex flex-col items-center gap-8 text-center">
        <div class="flex flex-col gap-2">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">技能 &amp; 工具</h2>
          <p class="text-muted-foreground">Nervefeyn 如何检索来源、保留研究连续性并渲染产物。</p>
        </div>
        <div class="grid w-full gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {sources.map((source) => (
            <Card client:load size="sm" className="text-center">
              <CardHeader client:load className="items-center">
                <CardTitle client:load>
                  {source.href ? (
                    <a href={source.href} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">
                      {source.name}
                    </a>
                  ) : (
                    source.name
                  )}
                </CardTitle>
                <CardDescription client:load>{source.description}</CardDescription>
              </CardHeader>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="flex flex-col items-center gap-8 text-center">
        <div class="flex flex-col gap-2">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">计算</h2>
          <p class="text-muted-foreground">工作流选择环境后,可选的研究实验执行目标。</p>
        </div>
        <div class="grid w-full gap-4 sm:grid-cols-3">
          {compute.map((provider) => (
            <Card client:load size="sm" className="text-center">
              <CardHeader client:load className="items-center">
                <CardTitle client:load>
                  <a href={provider.href} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">
                    {provider.name}
                  </a>
                </CardTitle>
                <CardDescription client:load>{provider.description}</CardDescription>
              </CardHeader>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="flex flex-col items-center gap-6 py-20 text-center">
      <p class="text-muted-foreground">
        基于 <a href="https://github.com/badlogic/pi-mono" class="text-primary hover:underline">Pi</a> 与 <a href="https://www.alphaxiv.org/" class="text-primary hover:underline">alphaXiv</a> 构建。能力以 Pi 技能发布,研究输出保持来源可追溯。
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/docs/getting-started/installation">
          <Button client:load size="lg">开始使用</Button>
        </a>
        <a href="https://github.com/NoWint/Nervefeyn" target="_blank" rel="noopener noreferrer">
          <Button client:load variant="outline" size="lg">在 GitHub 上查看</Button>
        </a>
      </div>
    </section>

  </div>

  <script is:inline>
    (function () {
      function init() {
        var toggles = Array.from(document.querySelectorAll(".install-toggle"))
        var btn = document.getElementById("install-cmd")
        var text = document.getElementById("install-command")
        var copyIcon = document.getElementById("install-copy")
        var checkIcon = document.getElementById("install-check")
        if (!btn || !text || !copyIcon || !checkIcon) return

        toggles.forEach(function (toggle) {
          if (toggle._b) return
          toggle._b = true
          toggle.addEventListener("click", function () {
            var cmd = toggle.getAttribute("data-command")
            if (!cmd) return
            btn.setAttribute("data-command", cmd)
            text.textContent = cmd
            toggles.forEach(function (t) {
              t.classList.remove("bg-muted", "text-foreground")
              t.classList.add("bg-muted/30", "text-muted-foreground", "hover:text-foreground", "hover:bg-muted/50")
            })
            toggle.classList.remove("bg-muted/30", "text-muted-foreground", "hover:text-foreground", "hover:bg-muted/50")
            toggle.classList.add("bg-muted", "text-foreground")
          })
        })

        if (!btn._b) {
          btn._b = true
          btn.addEventListener("click", function () {
            var cmd = btn.getAttribute("data-command")
            if (!cmd) return
            navigator.clipboard.writeText(cmd).then(function () {
              copyIcon.classList.add("hidden")
              checkIcon.classList.remove("hidden")
              setTimeout(function () {
                copyIcon.classList.remove("hidden")
                checkIcon.classList.add("hidden")
              }, 2000)
            })
          })
        }
      }
      init()
      document.addEventListener("astro:after-swap", init)
    })()
  </script>
</Layout>
